{
  "env": {
    "CLAUDE_CODE_DISABLE_AUTO_MEMORY": "1",
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1",
    "ENABLE_CLAUDEAI_MCP_SERVERS": "false",
    "MAX_THINKING_TOKENS": "31999",
    "DISABLE_AUTOUPDATER": "1"
  },
  "permissions": {
    "deny": [
      "AskUserQuestion"
    ],
    "defaultMode": "dontAsk"
  },
  "model": "claude-opus-4-6",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/dotfiles/claude/hook pre"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "~/dotfiles/claude/hook notification"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/dotfiles/claude/hook post"
          }
        ]
      }
    ],
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/dotfiles/claude/hook worktree-create"
          }
        ]
      }
    ],
    "WorktreeRemove": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/dotfiles/claude/hook worktree-remove"
          }
        ]
      }
    ]
  },
  "workflowKeywordTriggerEnabled": false,
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true
  },
  "language": "敬体",
  "effortLevel": "high",
  "promptSuggestionEnabled": false,
  "awaySummaryEnabled": false,
  "skipDangerousModePermissionPrompt": true,
  "editorMode": "vim",
  "verbose": false,
  "autoCompactEnabled": true,
  "fileCheckpointingEnabled": false,
  "terminalProgressBarEnabled": true,
  "remoteControlAtStartup": false,
  "voiceEnabled": true,
  "comment": "claude-fable-5[1m]",
  "autoUpdatesChannel": "stable"
}

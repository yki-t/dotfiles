#!/bin/bash

set -eu

TARGET="$HOME/di/ext"

is_mounted() {
  mountpoint -q "$TARGET" 2>/dev/null
}

info() {
  echo "[$(date +'%Y-%m-%d %H:%M:%S')] $*"
}

if is_mounted; then
  echo "Already mounted"
  exit 0
fi

# list LUKS devices (non-NVMe disks only)
info "Listing devices:"
uuids=()
while read -r uuid _ _; do
  if ! [[ $uuid =~ ^\{?[A-F0-9a-f]{8}-[A-F0-9a-f]{4}-[A-F0-9a-f]{4}-[A-F0-9a-f]{4}-[A-F0-9a-f]{12}\}?$ ]]; then
    continue
  fi
  if ! sudo file -sL "/dev/disk/by-uuid/$uuid" | grep -q LUKS; then
    continue
  fi
  uuids+=("$uuid")
done< <(sudo lsblk -o UUID,NAME,TYPE | grep disk | grep -v nvme)

# Check if any disk needs unlocking
has_locked=0
for uuid in "${uuids[@]}"; do
  id=$(echo "$uuid" | awk -F'-' '{print $1}')
  if ! lsblk | grep -q "r1-$id"; then
    has_locked=1
    break
  fi
done

info "Found ${#uuids[@]} LUKS devices."
if [ $has_locked -eq 1 ]; then
  info "Unlocking.."
  read -rsp "Enter passphrase: " passwd; echo
  for uuid in "${uuids[@]}"; do
    id=$(echo "$uuid" | awk -F'-' '{print $1}')
    if lsblk | grep -q "r1-$id"; then
      info "r1-$id already unlocked, skipping"
      continue
    fi
    info "Unlocking $uuid -> r1-$id"
    echo "$passwd" | sudo cryptsetup luksOpen "/dev/disk/by-uuid/$uuid" "r1-$id" &
  done
  wait
fi

# mount btrfs RAID1
if ! is_mounted; then
  info "Mounting btrfs RAID1.."
  # mount using the first available LUKS device
  for uuid in "${uuids[@]}"; do
    id=$(echo "$uuid" | awk -F'-' '{print $1}')
    if [ -e "/dev/mapper/r1-$id" ]; then
      sudo mount "/dev/mapper/r1-$id" "$TARGET"
      break
    fi
  done
fi

info 'done'
